# --- App ---
APP_ENV=local
SECRET_KEY=change-me-in-prod
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/ai_manager

# --- Redis (cache + ARQ queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant (vector store) ---
QDRANT_URL=http://localhost:6333

# --- Object storage (S3-compatible / MinIO local) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-manager

# --- AI providers (task_102 runs only in local mock mode) ---
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=local     # local | yandexgpt
YANDEX_API_KEY=
GIGACHAT_API_KEY=

# --- JWT ---
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=30
